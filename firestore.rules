rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'score', 'world', 'activeWorld', 'currentGameIndex', 'avatar']) 
        && data.name is string && data.name.size() <= 64 
        && data.avatar is string && data.avatar.size() <= 10
        && data.score is number 
        && data.world is number 
        && data.activeWorld is number 
        && data.currentGameIndex is number;
    }

    match /users/{nameId} {
      // Allow read/write based on name identifier validation
      allow read: if isValidId(nameId);
      
      allow create: if isValidId(nameId)
        && isValidUser(incoming())
        && incoming().name == nameId;

      allow update: if isValidId(nameId)
        && isValidUser(incoming())
        && incoming().name == existing().name
        && incoming().diff(existing()).affectedKeys().hasOnly(['avatar', 'score', 'world', 'activeWorld', 'currentGameIndex']);
    }
  }
}
