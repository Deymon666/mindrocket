rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'score', 'world', 'activeWorld', 'currentGameIndex', 'avatar']) 
        && data.name is string && data.name.size() > 0 && data.name.size() <= 64 
        && data.avatar is string && data.avatar.size() > 0 && data.avatar.size() <= 10
        && data.score is number 
        && data.world is number 
        && data.activeWorld is number 
        && data.currentGameIndex is number;
    }

    match /users/{userId} {
      // Must be authenticated and document ID must match the current authenticated user's uid
      allow read: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid
        && isValidUser(incoming())
        && (incoming().userId == userId || !incoming().keys().hasAny(['userId'])); // Validate optional userId if provided

      allow update: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid
        && isValidUser(incoming())
        && incoming().name == existing().name
        && incoming().diff(existing()).affectedKeys().hasOnly(['avatar', 'score', 'world', 'activeWorld', 'currentGameIndex']);
    }
  }
}
